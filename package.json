{
  "name": "@smoothsend/mcp",
  "version": "1.0.1",
  "description": "MCP server for SmoothSend — enables AI assistants to help developers integrate gasless transactions on Aptos",
  "type": "module",
  "bin": {
    "smoothsend-mcp": "./dist/index.js"
  },
